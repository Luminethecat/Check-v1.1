/* 和管理员登录页样式一致，直接复制 */
.container {
  padding: 60rpx 30rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 60rpx;
}
.form-item {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 30rpx;
}
.label {
  font-size: 28rpx;
  color: #333;
}
.input {
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  border: 1rpx solid #eee;
}
.login-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}
.to-admin-login {
  font-size: 24rpx;
  color: #1890ff;
  margin-top: 40rpx;
  text-decoration: underline;
}