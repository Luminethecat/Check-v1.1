.container {
  padding: 30rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}
.greet {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.type {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}
.logout-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #eee;
  color: #666;
  font-size: 24rpx;
  border-radius: 30rpx;
}
.menu-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}
.menu-item {
  height: 160rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(24,144,255,0.2);
}