/* 页面容器 */
.att-page {
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 日期选择栏 */
.date-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.date-btn {
  padding: 12rpx 16rpx;
  background-color: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 26rpx;
}
.query-btn {
  padding: 12rpx 24rpx;
  background-color: #2781ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

/* 打卡记录容器 */
.record-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 打卡记录卡片 */
.record-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 员工信息栏 */
.emp-info {
  display: flex;
  gap: 20rpx;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 1px solid #f0f0f0;
  font-size: 28rpx;
}
.emp-name {
  font-weight: 600;
  color: #333;
}
.emp-id {
  color: #666;
}

/* 打卡详情栏 */
.record-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}
.detail-item {
  line-height: 1.5;
}

/* 无数据提示 */
.empty-tip {
  padding: 80rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}