.container { padding: 30rpx; background: #f5f7fa; min-height: 100vh; }
.form-item { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 25rpx; }
.label { font-size: 28rpx; color: #333; }
.input { height: 80rpx; background: #fff; border-radius: 8rpx; padding: 0 20rpx; border: 1rpx solid #eee; }
.btn { width: 100%; height: 80rpx; background: #1890ff; color: #fff; border-radius: 8rpx; margin-top: 20rpx; }